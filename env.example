# Immich Swipe - Server Configuration
# These are read at RUNTIME by the Go backend (no rebuild needed)

# Your Immich server URL (default for login; required for env-configured users)
IMMICH_SERVER_URL=http://immich.home:2283

# Env API keys are OPTIONAL when using Immich account (email/password) login in the UI.
# Configure them only if you want auto-login / a preconfigured user picker.

# User 1 (optional - for auto-login / user selection)
IMMICH_API_KEY_1_NAME=Alice
IMMICH_API_KEY_1_KEY=your-api-key-here

# User 2 (optional)
IMMICH_API_KEY_2_NAME=Bob
IMMICH_API_KEY_2_KEY=another-api-key-here

# Add more users as needed (IMMICH_API_KEY_3_NAME, IMMICH_API_KEY_3_KEY, etc.)
# If no IMMICH_API_KEY_* vars are set, the login UI offers:
#   - Immich account (email + password; password login must be enabled on Immich)
#   - API key (server URL + API key)
