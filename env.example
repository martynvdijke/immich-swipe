# Immich Swipe - Server Configuration
# These are read at RUNTIME by the Go backend (no rebuild needed)

# Your Immich server URL (required for env-configured users)
IMMICH_SERVER_URL=http://immich.home:2283

# User 1 (optional - for auto-login / user selection)
IMMICH_API_KEY_1_NAME=Alice
IMMICH_API_KEY_1_KEY=your-api-key-here

# User 2 (optional)
IMMICH_API_KEY_2_NAME=Bob
IMMICH_API_KEY_2_KEY=another-api-key-here

# Add more users as needed (IMMICH_API_KEY_3_NAME, IMMICH_API_KEY_3_KEY, etc.)
# If no IMMICH_API_KEY_* vars are set, manual login is used (enter server URL + API key in the UI)
